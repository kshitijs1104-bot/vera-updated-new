From 97675a026c92f4c0f73619086aaf18edcd7cb40a Mon Sep 17 00:00:00 2001
From: Vera Fix <fix@vera.local>
Date: Sun, 5 Jul 2026 15:03:37 +0000
Subject: [PATCH 2/2] Fix: error responses render as if they were real answers

Two bugs compounding:

1. groq.ts: only the JSON-parse step had retry protection. The initial
   API call itself was unwrapped, so any transient network/rate-limit
   error on that first call threw straight past all retry logic into
   the route's generic catch-all, producing a generic 'unexpected error'
   response for queries that likely would have succeeded on one retry.
   Now the initial call gets the same one-retry protection as parsing.

2. Venus.tsx / venusHistory.ts: the frontend's render logic already had
   correct handling for isError (hide confidence badge, show a distinct
   red error box instead of cards) -- but isError/errorType were never
   copied from the API response onto the saved ChatMessage object in
   the onSuccess handler, and weren't even part of the ChatMessage type.
   So every error response silently lost its error flag and rendered
   identically to a real, confidently-badged answer. Added the fields
   to the type and wired them through.
---
 artifacts/api-server/src/lib/groq.ts         | 18 ++++++++++++++++--
 artifacts/vera-nexus/src/lib/venusHistory.ts |  2 ++
 artifacts/vera-nexus/src/pages/Venus.tsx     |  2 ++
 3 files changed, 20 insertions(+), 2 deletions(-)

diff --git a/artifacts/api-server/src/lib/groq.ts b/artifacts/api-server/src/lib/groq.ts
index eafb971..480abea 100644
--- a/artifacts/api-server/src/lib/groq.ts
+++ b/artifacts/api-server/src/lib/groq.ts
@@ -64,8 +64,22 @@ export async function callGroqJSON(
   params: GroqJsonParams,
   label: string,
 ): Promise<{ parsed: any | null; raw: string; errorType?: "parse" | "transient" }> {
-  const completion = await groq.chat.completions.create(params);
-  const raw = completion.choices[0]?.message?.content || "";
+  let raw: string;
+
+  try {
+    const completion = await groq.chat.completions.create(params);
+    raw = completion.choices[0]?.message?.content || "";
+  } catch (initialErr) {
+    console.error(`[callGroqJSON] "${label}" — initial API call itself threw, retrying once before giving up`, initialErr);
+    try {
+      const retryCompletion = await groq.chat.completions.create(params);
+      raw = retryCompletion.choices[0]?.message?.content || "";
+    } catch (retryErr) {
+      console.error(`[callGroqJSON] "${label}" — retry API call ALSO threw. Giving up.`, retryErr);
+      return { parsed: null, raw: "", errorType: "transient" };
+    }
+  }
+
   const candidate = extractJson(raw);
 
   try {

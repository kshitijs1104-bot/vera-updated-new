+/* Custom scrollbar — previously no scrollbar rules existed anywhere in this
+   file, so every scrollable panel (sidebar, chat pane) fell back to the
+   native OS scrollbar: a plain light-gray/white bar that reads as a jarring
+   foreign element against the dark theme. This restyles it to a thin,
+   low-contrast bar using the existing theme tokens so it recedes into the
+   design instead of standing out, and hides it entirely until the container
+   is hovered or actively scrolled so it isn't a persistent visual element
+   at all in the common case. Covers both WebKit (Chrome/Edge/Safari) and
+   Firefox, since `scrollbar-width`/`scrollbar-color` are Firefox-only and
+   the `::-webkit-scrollbar` family is WebKit-only — no single rule covers
+   both engines. */
+* {
+  scrollbar-width: thin;
+  scrollbar-color: transparent transparent;
+}
+
+*:hover {
+  scrollbar-color: hsl(var(--foreground) / 0.18) transparent;
+}
+
+*::-webkit-scrollbar {
+  width: 8px;
+  height: 8px;
+}
+
+*::-webkit-scrollbar-track {
+  background: transparent;
+}
+
+*::-webkit-scrollbar-thumb {
+  background-color: transparent;
+  border-radius: 9999px;
+  border: 2px solid transparent;
+  background-clip: padding-box;
+  transition: background-color 0.15s ease;
+}
+
+*:hover::-webkit-scrollbar-thumb {
+  background-color: hsl(var(--foreground) / 0.18);
+  background-clip: padding-box;
+}
+
+*::-webkit-scrollbar-thumb:hover {
+  background-color: hsl(var(--foreground) / 0.32);
+}
+
